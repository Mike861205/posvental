generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================== MULTI-TENANT CORE ======================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  city      String?
  phone     String?
  slug      String   @unique
  createdAt DateTime @default(now())

  // Control del sistema (superadmin)
  isBlocked       Boolean   @default(false)
  blockedAt       DateTime?
  blockReason     String?
  superadminNotes String?
  accessUntil     DateTime?
  monthlyFee      Decimal?  @db.Decimal(10, 2)
  billingMethod   SuperadminBillingMethod @default(TRANSFER)
  lastPaidAt      DateTime?
  paidCycles      Int       @default(0)

  // Pagos / configuración
  stripeSecretKey      String?
  stripePublicKey      String?
  mpAccessToken        String?
  currency             String  @default("MXN")

  // Personalización
  logoUrl              String?
  warnDaysBeforeExpiry Int     @default(5)

  users        User[]
  members      Member[]
  plans        Plan[]
  subscriptions Subscription[]
  payments     Payment[]
  products      Product[]
  productCategories ProductCategory[]
  cashRegisters CashRegister[]
  cashMovements CashMovement[]
  posSales      POSSale[]
  billingPayments TenantBillingPayment[]
}

enum SuperadminBillingMethod {
  TRANSFER
  STRIPE
}

model TenantBillingPayment {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(10, 2)
  method    SuperadminBillingMethod @default(TRANSFER)
  paidAt    DateTime @default(now())
  markedBy  String?
  notes     String?

  @@index([tenantId])
  @@index([paidAt])
}

enum Role {
  OWNER
  ADMIN
  STAFF
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(OWNER)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ====================== NEGOCIO ======================

model Member {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName  String
  photoUrl  String?
  email     String?
  phone     String?
  birthDate DateTime?
  notes     String?
  createdAt DateTime @default(now())

  subscriptions Subscription[]

  @@index([tenantId])
}

model Plan {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String   // Zumba, Crossfit, Gym, JumpiFit...
  description String?
  price       Decimal  @db.Decimal(10, 2)
  durationDays Int     @default(30)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  subscriptions Subscription[]

  @@index([tenantId])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

model Subscription {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id])
  startDate DateTime @default(now())
  endDate   DateTime
  price     Decimal  @db.Decimal(10, 2)
  status    SubscriptionStatus @default(ACTIVE)
  createdAt DateTime @default(now())

  payments  Payment[]

  @@index([tenantId])
  @@index([memberId])
}

enum PaymentMethod {
  CASH
  STRIPE
  MERCADOPAGO
  TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Payment {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  amount         Decimal  @db.Decimal(10, 2)
  method         PaymentMethod @default(CASH)
  status         PaymentStatus @default(PAID)
  externalId     String?
  createdAt      DateTime @default(now())

  @@index([tenantId])
}

// ====================== PRODUCTOS Y POS ======================

model ProductCategory {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  products Product[]

  @@index([tenantId])
  @@unique([tenantId, name])
}

model Product {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name      String
  imageUrl  String?
  code      String?
  cost      Decimal  @default(0) @db.Decimal(10, 2)
  price     Decimal  @db.Decimal(10, 2)
  stock     Int      @default(0)
  featured  Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems POSSaleItem[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([tenantId, code])
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

model CashRegister {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status       CashRegisterStatus @default(OPEN)
  openingCash  Decimal  @default(0) @db.Decimal(12, 2)
  closingCash  Decimal? @db.Decimal(12, 2)
  expectedCash Decimal? @db.Decimal(12, 2)
  difference   Decimal? @db.Decimal(12, 2)
  notes        String?
  openedAt     DateTime @default(now())
  closedAt     DateTime?
  openedById   String?
  closedById   String?

  movements CashMovement[]
  sales     POSSale[]

  @@index([tenantId])
  @@index([tenantId, status])
}

enum CashMovementType {
  INCOME
  EXPENSE
}

model CashMovement {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registerId  String
  register    CashRegister @relation(fields: [registerId], references: [id], onDelete: Cascade)
  type        CashMovementType
  concept     String
  amount      Decimal  @db.Decimal(12, 2)
  method      PaymentMethod @default(CASH)
  createdAt   DateTime @default(now())
  createdById String?

  @@index([tenantId])
  @@index([registerId])
}

enum POSPaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT
}

enum POSSaleStatus {
  PAID
  CREDIT
  CANCELED
}

model POSSale {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registerId   String?
  register     CashRegister? @relation(fields: [registerId], references: [id])
  customer     String?
  subtotal     Decimal  @db.Decimal(12, 2)
  discount     Decimal  @default(0) @db.Decimal(12, 2)
  total        Decimal  @db.Decimal(12, 2)
  method       POSPaymentMethod @default(CASH)
  status       POSSaleStatus    @default(PAID)
  cashReceived Decimal? @db.Decimal(12, 2)
  changeGiven  Decimal? @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime @default(now())
  createdById  String?

  items POSSaleItem[]

  @@index([tenantId])
  @@index([registerId])
}

model POSSaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      POSSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  name      String
  price     Decimal  @db.Decimal(12, 2)
  quantity  Int
  total     Decimal  @db.Decimal(12, 2)

  @@index([saleId])
  @@index([productId])
}
